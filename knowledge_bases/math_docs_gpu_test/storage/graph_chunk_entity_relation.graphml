    <node id="Q-Analogue">
      <data key="d0">Q-Analogue</data>
      <data key="d1">concept</data>
      <data key="d2">A mathematical analogue to concepts such as factorials or identities discussed in the context of q-series.</data>
      <data key="d3">chunk-90fca6d9f1f9b0dbe01302d6bf68c233</data>
      <data key="d4">math1.pdf</data>
      <data key="d5">1774690322</data>
      <data key="d6" />
    </node>
    <node id="Shifted Factorial">
      <data key="d0">Shifted Factorial</data>
      <data key="d1">concept</data>
      <data key="d2">A construct defined for positive integers n and a variable x with (x)0 = 1.</data>
      <data key="d3">chunk-90fca6d9f1f9b0dbe01302d6bf68c233</data>
      <data key="d4">math1.pdf</data>
      <data key="d5">1774690322</data>
      <data key="d6" />
    </node>
    <node id="Q-Shifted Factorial">
      <data key="d0">Q-Shifted Factorial</data>
      <data key="d1">concept</data>
      <data key="d2">A q-analogue of the shifted factorial defined for complex numbers a where |q| &lt; 1.</data>
      <data key="d3">chunk-90fca6d9f1f9b0dbe01302d6bf68c233</data>
      <data key="d4">math1.pdf</data>
      <data key="d5">1774690322</data>
      <data key="d6" />
    </node>
    <node id="Generalized Hypergeometric Series">
      <data key="d0">Generalized Hypergeometric Series</data>
      <data key="d1">concept</data>
      <data key="d2">Series defined with specific notation, referring to Bailey’s classic text.</data>
      <data key="d3">chunk-90fca6d9f1f9b0dbe01302d6bf68c233</data>
      <data key="d4">math1.pdf</data>
      <data key="d5">1774690322</data>
      <data key="d6" />
    </node>
    <node id="Backward Difference Operator">
      <data key="d0">Backward Difference Operator</data>
      <data key="d1">method</data>
      <data key="d2">An operator defined as nabla tau_n = tau_n - tau_n-1.</data>
      <data key="d3">chunk-90fca6d9f1f9b0dbe01302d6bf68c233</data>
      <data key="d4">math1.pdf</data>
      <data key="d5">1774690322</data>
      <data key="d6" />
    </node>
    <node id="Forward Difference Operator">
      <data key="d0">Forward Difference Operator</data>
      <data key="d1">method</data>
      <data key="d2">An operator defined as delta tau_n = tau_n - tau_n+1.</data>
      <data key="d3">chunk-90fca6d9f1f9b0dbe01302d6bf68c233</data>
      <data key="d4">math1.pdf</data>
      <data key="d5">1774690322</data>
      <data key="d6" />
    </node>
    <node id="Gospers Identity">
      <data key="d0">Gospers Identity</data>
      <data key="d1">content</data>
      <data key="d2">An identity for which a new q-analogue is presented, inequivalent to Yamaguchi's q-analogue.</data>
      <data key="d3">chunk-90fca6d9f1f9b0dbe01302d6bf68c233</data>

    <node id="Abel Lemma">
      <data key="d0">Abel Lemma</data>
      <data key="d1">concept</data>
      <data key="d2">A lemma on summation by parts used as a basis for a modified technique.</data>
      <data key="d3">chunk-90fca6d9f1f9b0dbe01302d6bf68c233</data>
      <data key="d4">math1.pdf</data>

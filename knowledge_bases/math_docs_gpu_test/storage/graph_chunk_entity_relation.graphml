    <node id="Modified Abel Lemma">
      <data key="d0">Modified Abel Lemma</data>
      <data key="d1">concept</data>
      <data key="d2">A variation of the Abel lemma on summation by parts, assumed to converge for the research.</data>
      <data key="d3">chunk-90fca6d9f1f9b0dbe01302d6bf68c233</data>
      <data key="d4">math1.pdf</data>
      <data key="d5">1774690322</data>

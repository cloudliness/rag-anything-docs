        },
        {
            "type": "equation_interline",
            "content": {
                "math_content": "{ } _ { r } \\phi _ { r - 1 } \\left[ \\begin{array} { c } a _ { 1 } , a _ { 2 } , \\ldots , a _ { r } \\\\ b _ { 1 } , b _ { 2 } , \\ldots , b _ { r - 1 } \\end{array} ; q , x \\right] = \\sum _ { n = 0 } ^ { \\infty } \\frac { ( a _ { 1 } ; q ) _ { n } ( a _ { 2 } ; q ) _ { n } \\cdots ( a _ { r } ; q ) _ { n } } { ( q ; q ) _ { n } ( b _ { 1 } ; q ) _ { n } ( b _ { 2 } ; q ) _ { n } \\cdots ( b _ { r - 1 } ; q ) _ { n } } x ^ { n } ,",

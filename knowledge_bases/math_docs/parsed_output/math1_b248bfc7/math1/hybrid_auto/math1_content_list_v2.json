        {
            "type": "equation_interline",
            "content": {
                "math_content": "\\left[ \\begin{array}{c} a _ {1}, a _ {2}, \\dots , a _ {r} \\\\ b _ {1}, b _ {2}, \\dots , b _ {s} \\end{array} ; q \\right] _ {n} = \\frac {(a _ {1} ; q) _ {n} (a _ {2} ; q) _ {n} \\cdots (a _ {r} ; q) _ {n}}{(b _ {1} ; q) _ {n} (b _ {2} ; q) _ {n} \\cdots (b _ {s} ; q) _ {n}}",

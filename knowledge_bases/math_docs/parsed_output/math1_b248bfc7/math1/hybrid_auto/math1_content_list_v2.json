        {
            "type": "equation_interline",
            "content": {
                "math_content": "\\left[ \\begin{array}{c} a _ {1}, a _ {2}, \\ldots , a _ {r} \\\\ b _ {1}, b _ {2}, \\ldots , b _ {s} \\end{array} ; q \\right] _ {\\infty} = \\frac {(a _ {1} ; q) _ {\\infty} (a _ {2} ; q) _ {\\infty} \\cdots (a _ {r} ; q) _ {\\infty}}{(b _ {1} ; q) _ {\\infty} (b _ {2} ; q) _ {\\infty} \\cdots (b _ {s} ; q) _ {\\infty}}.",

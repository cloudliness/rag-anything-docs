                    {
                        "type": "equation_inline",
                        "content": "| q | < 1"
                    },
                    {
                        "type": "text",
                        "content": ", we recall the standard notation for "
                    },
                    {
                        "type": "equation_inline",
                        "content": "q"
                    },
                    {
                        "type": "text",
                        "content": "-shifted factorials. For a complex number "
                    },
                    {
                        "type": "equation_inline",
                        "content": "a"
                    },
                    {
                        "type": "text",
                        "content": ", the "
                    },
                    {
                        "type": "equation_inline",

                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "1.1. Preliminaries. The shifted factorial is such that "
                    },
                    {
                        "type": "equation_inline",
                        "content": "( x ) _ { 0 } = 1"
                    },
                    {
                        "type": "text",
                        "content": "and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "( x ) _ { n } = x ( x + 1 ) \\cdots ( x + n - 1 )"
                    },
                    {
                        "type": "text",
                        "content": "for positive integers n. Generalized hypergeometric series may then be defined so that "
                    }
                ]
            },

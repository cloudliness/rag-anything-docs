        {
            "type": "paragraph",
            "content": {
                "paragraph_content": [
                    {
                        "type": "text",
                        "content": "For a sequence "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\left( \\tau _ { n } : n \\in \\mathbb { N } _ { 0 } \\right)"
                    },
                    {
                        "type": "text",
                        "content": ", define the backward difference operator "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\nabla"
                    },
                    {
                        "type": "text",
                        "content": "and the forward difference operator "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\Delta"
                    },
                    {
                        "type": "text",
                        "content": "so that "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\nabla \\tau _ { n } = \\tau _ { n } - \\tau _ { n - 1 }"
                    },
                    {
                        "type": "text",
                        "content": "and "
                    },
                    {
                        "type": "equation_inline",
                        "content": "\\Delta \\tau _ { n } = \\tau _ { n } - \\tau _ { n + 1 }"
                    },
                    {
                        "type": "text",
                        "content": ". Being consistent with a number of research contributions from Chu et al. [8, 10, 11, 12] that have inspired our work, we let the relation "
                    }

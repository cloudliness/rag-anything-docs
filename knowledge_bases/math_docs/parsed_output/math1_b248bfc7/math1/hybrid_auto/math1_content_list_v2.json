        {
            "type": "equation_interline",
            "content": {
                "math_content": "\\begin{array}{l} (a; q) _ {0} = 1, \\\\ (a; q) _ {n} = \\prod_ {k = 0} ^ {n - 1} \\left(1 - a q ^ {k}\\right), \\quad n \\geq 1, \\\\ (a; q) _ {\\infty} = \\prod_ {k = 0} ^ {\\infty} \\left(1 - a q ^ {k}\\right). \\\\ \\end{array}",
                "math_type": "latex",
                "image_source": {
                    "path": "images/e4c699e628513d75a130ecc1ec0ddc8a1bf7f34d542df98b9c787a8efb364644.jpg"
                }
